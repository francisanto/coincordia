generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model User {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  walletAddress   String   @unique
  nickname        String?
  totalAuraPoints Int      @default(0)
  totalContributed Float   @default(0) // Mongo doesn’t support Decimal in Prisma
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AdminLog {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  action       String
  details      Json?
  adminAddress String?
  createdAt    DateTime @default(now())
}

model SystemStat {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  totalGroups  Int      @default(0)
  totalUsers   Int      @default(0)
  totalVolume  Float    @default(0)
  updatedAt    DateTime @updatedAt
}
